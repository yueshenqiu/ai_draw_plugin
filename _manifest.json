{
  "manifest_version": 2,
  "version": "2.0.0",
  "name": "AI Draw 图片生成插件",
  "description": "AI 绘图插件。命令前缀 /ad。支持多模型热切换、LLM 提示词生成、画师/风格预设、自拍模式、图生图/参考模式、双发送模式、自动撤回。Provider 架构预留扩展其他服务商。",
  "author": {
    "name": "三花",
    "url": "https://github.com/yueshenqiu"
  },
  "license": "GPL-v3.0-or-later",
  "urls": {
    "repository": "https://github.com/yueshenqiu/ai_draw_plugin",
    "homepage": "https://github.com/yueshenqiu/ai_draw_plugin"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.4.0"
  },
  "sdk": {
    "min_version": "2.5.0",
    "max_version": "2.99.0"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.image",
    "send.forward",
    "send.custom",
    "message.get_recent",
    "llm.generate",
    "db.query",
    "db.save",
    "config.get",
    "api.call",
    "emoji.get_random"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": ["zh-CN"]
  },
  "id": "rabbit.ai-draw-plugin"
}
