# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# 运行时生成的临时图片
temp_images/

# 个人自拍参考图（保留空目录，里面的图片不提交）
selfie_refs/*
!selfie_refs/.gitkeep

# 本地敏感配置（如自行复制一份带密钥的配置，请勿提交）
config.local.toml
*.local.toml

# WebUI 保存配置时生成的带密钥备份（含真实 key/token，严禁提交）
config_back/
*.backup.*
*.bak

# 编辑器/系统
.vscode/
.idea/
.DS_Store
Thumbs.db
